import tensorflow as tf
from tensorflow.keras import layers, models, backend as K

def swish(x):
    return x * tf.keras.backend.sigmoid(x)

def se_block(input_tensor, reduction=16):
    filters = input_tensor.shape[-1]
    se = layers.GlobalAveragePooling2D()(input_tensor)
    se = layers.Dense(filters // reduction, activation='relu')(se)
    se = layers.Dense(filters, activation='sigmoid')(se)
    se = layers.Reshape((1, 1, filters))(se)
    return layers.multiply([input_tensor, se])

def conv_block(x, filters, kernel_size=(3, 3), separable=False):
    if separable:
        x = layers.SeparableConv2D(filters, kernel_size, padding='same')(x)
    else:
        x = layers.Conv2D(filters, kernel_size, padding='same')(x)
    x = layers.Activation(swish)(x)

    return x

input_layer = layers.Input(shape=(128, 128, 3))

# Block 1
x = conv_block(input_layer, 32)
x = conv_block(x, 32)
res1 = x  # Shape: (128, 128, 32)
x = layers.MaxPooling2D((2, 2))(x) 

# Block 2
x = conv_block(x, 64)
x = conv_block(x, 64)  # Shape: (64, 64, 64)
res1_down = layers.MaxPooling2D((2, 2))(res1) 
res1_adjusted = layers.Conv2D(64, (1, 1), padding='same')(res1_down)  
x = layers.Add()([x, res1_adjusted])  
res2 = x  # Shape: (64, 64, 64)

x = layers.MaxPooling2D((2, 2))(x) 

# Block 3 (Depthwise Separable)
x = conv_block(x, 128, separable=True)
x = conv_block(x, 128, separable=True) 
res2_down = layers.MaxPooling2D((2, 2))(res2) 
res2_adjusted = layers.Conv2D(128, (1, 1), padding='same')(res2_down)  
x = layers.Add()([x, res2_adjusted])  
res3 = x  # Shape: (32, 32, 128)

x = layers.MaxPooling2D((2, 2))(x) 

# Block 4 (Depthwise Separable + SE)
x = conv_block(x, 128, separable=True)
x = se_block(x)  # SE block
x = conv_block(x, 128, separable=True) 
x = layers.Dropout(0.3)(x)
res3_down = layers.MaxPooling2D((2, 2))(res3) 
x = layers.Add()([x, res3_down]) 
res4 = x  # Shape: (16, 16, 128)

x = layers.MaxPooling2D((2, 2))(x)  

# Block 5 (Depthwise Separable)
x = conv_block(x, 256, separable=True)
x = conv_block(x, 256, separable=True)  
res4_down = layers.MaxPooling2D((2, 2))(res4) 
res4_adjusted = layers.Conv2D(256, (1, 1), padding='same')(res4_down)  
x = layers.Add()([x, res4_adjusted])
res5 = x  # Shape: (8, 8, 256)

x = layers.MaxPooling2D((2, 2))(x)  

# Block 6 (Depthwise Separable + SE)
x = conv_block(x, 256, separable=True)
x = se_block(x)
x = conv_block(x, 256, separable=True)  
x = layers.Dropout(0.3)(x)
res5_down = layers.MaxPooling2D((2, 2))(res5)  
x = layers.Add()([x, res5_down])  

x = layers.GlobalAveragePooling2D()(x) 

# Dense Layers
x = layers.Dense(512, activation='swish')(x)
x = layers.Dense(128, activation='swish')(x)
x = layers.Dense(64, activation='swish')(x)
x = layers.Dense(32, activation='swish')(x)


output = layers.Dense(1, activation='sigmoid')(x)


model = models.Model(inputs=input_layer, outputs=output)
# Define learning rate scheduler
lr_schedule = tf.keras.optimizers.schedules.ExponentialDecay(
    initial_learning_rate=1e-4, decay_steps=1000, decay_rate=0.95
)

model.compile(
    optimizer=tf.keras.optimizers.Adam(learning_rate=lr_schedule),
    loss='binary_crossentropy',
    metrics=['accuracy']
)

model.summary()